# EZ Up Trading Bot Configuration
# Copy this to .env and fill in your values

# ============ REQUIRED ============

# Private key for signing transactions (without 0x prefix)
# Format: 64 hex characters
# ⚠️  NEVER commit this to GitHub
TRADER_PRIVATE_KEY=your_private_key_here

# Bot wallet address (the one receiving/sending tokens)
# Format: 0x...
BOT_WALLET=0xYourWalletAddressHere

# ============ OPTIONAL ============

# Base RPC URL (defaults to public endpoint if not set)
# Free tier is rate-limited; consider using private endpoint for production
BASE_RPC_URL=https://mainnet.base.org

# EZ Path API key (if required for higher rate limits)
# EZ_PATH_API_KEY=your_key_here

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# ============ DEPLOYMENT (GitHub Actions) ============
# When deploying to GitHub Actions:
# 1. Add TRADER_PRIVATE_KEY as a repository secret
# 2. Add BOT_WALLET as a repository secret
# 3. Optionally add BASE_RPC_URL as a secret
# 4. Workflow will read these at runtime

# GitHub settings:
# Settings > Secrets and variables > Actions > New repository secret
