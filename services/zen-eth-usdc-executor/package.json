{
  "name": "zen-eth-usdc-executor",
  "version": "2.0.0",
  "description": "V2 Stateless 3-Asset Executor: ZEN/ETH/USDC with per-pair isolation, 90-day volatility adjustment, and Alpha Depth priority",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "tick": "tsx src/index.ts",
    "monitor": "tsx src/price-monitor.ts",
    "dashboard": "tsx src/dashboard.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "dotenv": "^16.3.1",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "plugin-ezpath": "^0.2.0",
    "viem": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
