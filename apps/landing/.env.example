# EZ Up Landing — environment variables
#
# All values are OPTIONAL. The landing page works out of the box with sensible
# defaults; override here or in the Vercel dashboard if you want to customize.

# Paste your Juicebox project URL (e.g. https://juicebox.money/v2/p/123).
# If unset, the CTA button uses a placeholder.
VITE_JUICEBOX_URL=https://juicebox.money/v2/p/YOUR_PROJECT_ID

# (Optional) Override the public Base RPC with your own (Alchemy, Infura, etc.)
# Default: https://mainnet.base.org
# VITE_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# (Optional) Override the public history.json data feed URL.
# Default: this repo's main branch
# VITE_HISTORY_URL=https://raw.githubusercontent.com/infiniteezverse/ez-up/main/services/zen-usdc-trader/state/history.json
